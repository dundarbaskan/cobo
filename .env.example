# ─── Cobo API ────────────────────────────────────────────────────────────────
COBO_API_KEY=
COBO_API_SECRET=
COBO_WALLET_ID=
COBO_API_HOST=https://api.cobo.com/v2

# ─── Cüzdan Adresleri ────────────────────────────────────────────────────────
MAIN_WALLET=
ETH_CONVERTER_WALLET=
BTC_CONVERTER_WALLET=
TRX_CONVERTER_WALLET=
# true → gelen coinler anında ilgili cüzdana transfer edilir | false → routing yapılmaz
COBO_AUTO_ROUTING_ENABLED=true

# ─── Veritabanı ──────────────────────────────────────────────────────────────
MONGODB_URL=mongodb+srv://<kullanici>:<sifre>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ─── Güvenlik ────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=
ADMIN_USERNAME=
ADMIN_PASSWORD=
IBAN_MANAGER_USERNAME=
IBAN_MANAGER_PASSWORD=

# ─── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── MT5 ─────────────────────────────────────────────────────────────────────
MT5_SERVER=<ip>:<port>
MT5_LOGIN=
MT5_PASSWORD=
MT5_GROUP_MASK=*

# ─── Onramper ────────────────────────────────────────────────────────────────
ONRAMPER_API_KEY=
ONRAMPER_SECRET_KEY=
ONRAMPER_WIDGET_URL=https://buy.onramper.dev
ONRAMPER_WEBHOOK_SECRET=
ONRAMPER_DEFAULT_CRYPTO=USDT
ONRAMPER_DEFAULT_NETWORK=tron
ONRAMPER_DEFAULT_FIAT=TRY
ONRAMPER_DEFAULT_AMOUNT=1000

# ─── Sunucu & Uygulama ───────────────────────────────────────────────────────
PORT=8000
SERVER_IP=
ALLOWED_TEST_IP=
APP_BASE_URL=https://

# ─── İş Kuralları ────────────────────────────────────────────────────────────
COMPANY_NAME=
DEFAULT_AGENT_NAME=
COMMISSION_RATE_PERCENT=0
MIN_DEPOSIT_USD_LIMIT=1.0

# ─── Opsiyonel: Telegram Admin ID'leri (virgülle ayrılmış) ───────────────────
# Boş bırakılırsa config/settings.py içindeki statik liste kullanılır
# ALLOWED_ADMIN_TELEGRAM_IDS=123456789,987654321

# ─── CRM (Eski sistem referansı) ─────────────────────────────────────────────
CRM_EMAIL=
CRM_PASSWORD=
